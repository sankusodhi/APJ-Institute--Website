# APJ Institute Backend - Environment Configuration Example
# Copy this file to .env and update with your actual values

# ============================
# DATABASE CONFIGURATION
# ============================
# Format: mysql://username:password@host:port/database
# Example: mysql://root:password123@localhost:3306/apj_institute
DATABASE_URL="mysql://root:your_password@localhost:3306/apj_institute"

# ============================
# JWT AUTHENTICATION
# ============================
# Secret key for JWT token (min 32 characters, use strong random string)
# Generate: openssl rand -base64 32
JWT_SECRET="your_jwt_secret_key_here_min_32_characters_long_secure_key_123456"

# Token expiration time
JWT_EXPIRE="7d"

# ============================
# SERVER CONFIGURATION
# ============================
# Server port
PORT=5000

# Node environment
NODE_ENV="development"

# ============================
# FILE UPLOAD CONFIGURATION
# ============================
# Maximum file size in bytes (5MB = 5242880)
MAX_FILE_SIZE=5242880

# Upload directory
UPLOAD_DIR="./uploads"

# ============================
# CORS CONFIGURATION
# ============================
# Frontend URL for CORS
CLIENT_URL="http://localhost:5173"

# ============================
# ADMIN CREDENTIALS (Optional)
# ============================
# Use these for initial admin creation script
ADMIN_EMAIL="admin@apjinstitute.com"
ADMIN_PASSWORD="Admin@123"

# ============================
# NOTES
# ============================
# 1. Never commit .env file to git
# 2. Keep JWT_SECRET secure and strong
# 3. Update DATABASE_URL with your MySQL credentials
# 4. Update CLIENT_URL if frontend runs on different port
# 5. For production, use strong passwords and secret keys
